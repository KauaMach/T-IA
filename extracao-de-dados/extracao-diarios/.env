# Configuração do Pipeline de Diários Oficiais

# Caminho da pasta que será processada (ex: dados/diarios-oficiais/Dados-Tabuleiros do Alto Parnaíba-002)
INPUT_FOLDER_PATH=dados/diarios-oficiais/Dados-Vale dos Rios Piauí e Itaueiras-001

# Nome dos arquivos de saída (sem extensão)
OUTPUT_FILENAME=diarios_Vales

# Configurações de Memória
PYTORCH_ALLOC_CONF=expandable_segments:True
